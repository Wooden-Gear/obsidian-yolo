    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "obsidian": "latest",
    "postcss": "^8.5.6",
