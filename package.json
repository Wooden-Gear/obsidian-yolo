{
  "name": "obsidian-yolo",
  "version": "1.5.12.5",
  "description": "AI chat with note context, smart writing assistance, and one-click edits for your vault.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -n app,styles -c blue,magenta \"npm:dev:app\" \"npm:styles:watch\"",
    "dev:app": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && npm run styles:build && node esbuild.config.mjs production",
    "styles:build": "postcss src/styles/index.css -o styles.css",
    "styles:watch": "postcss src/styles/index.css -o styles.css -w",
    "seed:long-chat": "node generate-long-chat.mjs",
    "version": "node version-bump.mjs",
    "prettier:check": "prettier --check --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache src __mocks__ app.css drizzle.config.ts eslint.config.mjs postcss.config.cjs",
    "prettier:write": "prettier --write --cache --cache-strategy content --cache-location node_modules/.cache/.prettiercache src __mocks__ app.css drizzle.config.ts eslint.config.mjs postcss.config.cjs",
    "lint": "npm run lint:check",
    "lint:check": "npm run prettier:check && eslint --cache --cache-location node_modules/.cache/.eslintcache src __mocks__ drizzle.config.ts",
    "lint:fix": "npm run prettier:write && eslint --cache --cache-location node_modules/.cache/.eslintcache --fix src __mocks__ drizzle.config.ts",
    "type:check": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsconfig.typecheck.tsbuildinfo",
    "test": "jest --maxWorkers=50%",
    "test:watch": "jest --watch",
    "test:changed": "jest -o",
    "models:update:openrouter": "node scripts/update-openrouter-model-capabilities.mjs",
    "migrate:compile": "node compile-migration.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cross-spawn": "^6.0.6",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^16.11.6",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/semver": "^7.5.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "builtin-modules": "3.3.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.3",
    "esbuild": "0.17.3",
    "eslint": "^9.39.2",
